#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
current_task="$repo_root/tasks/current.md"
python_cmd="${PYTHON:-python3}"

yellow='\033[1;33m'
red='\033[0;31m'
green='\033[0;32m'
reset='\033[0m'

zero_sha="0000000000000000000000000000000000000000"

# Parse stdin to build the commit range being pushed.
# Git pre-push receives lines: <local_ref> <local_sha> <remote_ref> <remote_sha>
commit_range=""
while read -r local_ref local_sha remote_ref remote_sha; do
  # Skip branch deletions
  [[ "$local_sha" == "$zero_sha" ]] && continue

  if [[ "$remote_sha" == "$zero_sha" ]]; then
    # New branch — compare against the merge-base with the default branch
    default_branch="$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|refs/remotes/origin/||' || echo main)"
    base="$(git merge-base "$default_branch" "$local_sha" 2>/dev/null || echo "")"
    if [[ -n "$base" ]]; then
      commit_range="${base}..${local_sha}"
    fi
  else
    commit_range="${remote_sha}..${local_sha}"
  fi
done

warn_unchecked_boxes() {
  local task_file="$1"

  [[ -f "$task_file" ]] || return 0

  if grep -qF '[User story copied from backlog]' "$task_file" && grep -qF '- [ ] [criterion]' "$task_file"; then
    return 0
  fi

  mapfile -t unchecked < <(
    grep -nE '^- \[ \]' "$task_file" \
      | grep -vF '[criterion]' \
      | grep -vF '[step]' \
      || true
  )

  [[ ${#unchecked[@]} -eq 0 ]] && return 0

  echo -e "${yellow}Warning:${reset} unchecked items remain in tasks/current.md:"
  for item in "${unchecked[@]}"; do
    echo "  $item"
  done

  if [[ -t 1 ]]; then
    local reply
    read -r -p "Continue push anyway? [y/N] " reply </dev/tty
    case "$reply" in
      y|Y|yes|YES) ;;
      *)
        echo -e "${red}Push cancelled.${reset}"
        exit 1
        ;;
    esac
  else
    echo -e "${yellow}Non-interactive push:${reset} leaving unchecked-item warning as informational only."
  fi
}

run_understanding_gate() {
  local gate_script="$repo_root/scripts/check_understanding_gate.py"

  if [[ ! -f "$gate_script" ]]; then
    echo -e "${yellow}Warning:${reset} $gate_script not found; skipping understanding gate."
    return 0
  fi

  if ! command -v "$python_cmd" >/dev/null 2>&1; then
    echo -e "${red}Error:${reset} Python interpreter '$python_cmd' not available."
    echo "Set PYTHON=/path/to/python or install python3 to run the understanding gate."
    exit 1
  fi

  local gate_args=(--repo-root "$repo_root" --task-file tasks/current.md --threshold-percent 80)
  if [[ -n "$commit_range" ]]; then
    gate_args+=(--commit-range "$commit_range")
  fi

  echo "Running understanding gate..."
  if ! "$python_cmd" "$gate_script" "${gate_args[@]}"; then
    echo -e "${red}Push blocked by understanding gate.${reset}"
    exit 1
  fi

  echo -e "${green}Understanding gate passed.${reset}"
}

warn_unchecked_boxes "$current_task"
run_understanding_gate
